# AWS credentials
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_DEFAULT_REGION=us-east-1

# HuggingFace (for vLLM model download)
HF_TOKEN=hf_your_token_here

# LiteLLM proxy
LITELLM_MASTER_KEY=sk-your-master-key
LITELLM_PROXY_URL=http://localhost:4000
LITELLM_API_KEY=sk-local

# vLLM model
VLLM_MODEL_ID=mistral-7b-finetuned-credit

# DynamoDB
DYNAMODB_TABLE=pipeline-audit-log

# SNS alerts
SNS_ALERT_TOPIC_ARN=arn:aws:sns:us-east-1:ACCOUNT_ID:ml-deployment-alerts
